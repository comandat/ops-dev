# ─────────────────────────────────────────────
# OpenSales – Root .gitignore
# ─────────────────────────────────────────────

# Dependencies (NEVER commit these)
node_modules/
.pnp
.pnp.*

# Build outputs (regenerated at deploy time)
dist/
build/
out/
.next/

# Databases
*.db
*.db-journal
*.sqlite


# Prisma generated client (generated at build)
generated/prisma/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test outputs
coverage/
test-results/
*.pid
*.seed
*.pid.lock

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Temporary
.temp
.tmp
tmp/
qa-suite/


# Uploads (runtime data, not code)
backend/uploads/

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
