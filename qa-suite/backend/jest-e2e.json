{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "../../backend",
  "roots": [
    "<rootDir>/../qa-suite/backend"
  ],
  "moduleDirectories": [
    "node_modules",
    "<rootDir>/node_modules"
  ],
  "testEnvironment": "node",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "setupFiles": [
    "<rootDir>/../qa-suite/backend/jest-setup.ts"
  ],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(uuid|lucia|@lucia-auth|oslo|@oslojs)/)"
  ],
  "testTimeout": 30000
}